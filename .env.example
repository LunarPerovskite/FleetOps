# FleetOps Environment Configuration

# Application
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql://fleetops:changeme@localhost:5432/fleetops
DB_USER=fleetops
DB_PASSWORD=changeme
DB_NAME=fleetops
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379

# Security
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Frontend
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# Providers (Optional - configure via UI)
# AUTH_PROVIDER=clerk
# CLERK_API_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...

# Email (Optional)
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=SG.xxx

# Storage (Optional)
# STORAGE_PROVIDER=local
# S3_BUCKET=fleetops-uploads
# AWS_ACCESS_KEY=AKIA...
# AWS_SECRET_KEY=...

# Monitoring (Optional)
# MONITORING_PROVIDER=sentry
# SENTRY_DSN=https://...

# Backup (Optional)
# S3_BACKUP_BUCKET=fleetops-backups
# BACKUP_RETENTION_DAYS=30

# ═══════════════════════════════════════
# PERSONAL AI AGENT CONNECTORS
# ═══════════════════════════════════════

# OpenClaw - Session-based autonomous agent
# OPENCLAW_URL=http://localhost:8080
# OPENCLAW_API_KEY=your-openclaw-api-key
# OPENCLAW_TIMEOUT=300
# OPENCLAW_MAX_STEPS=50

# Hermes - Task-based personal AI assistant
# HERMES_URL=http://localhost:9090
# HERMES_API_KEY=your-hermes-api-key
# HERMES_TIMEOUT=300
# HERMES_PERSONA=professional

# Ollama - Local LLM (runs on your machine)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama2

# Custom Agent - Any agent with HTTP API
# CUSTOM_AGENT_URL=http://localhost:9999
# CUSTOM_AGENT_API_KEY=your-agent-key

# Agent Execution Settings
# AGENT_AUTO_APPROVE_LOW_RISK=false
# AGENT_MAX_EXECUTION_TIME=3600
