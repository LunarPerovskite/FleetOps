#!/usr/bin/env python3
"""FleetOps CLI

Management tool for FleetOps operations.
Usage: fleetops [command] [options]

Commands:
    status          Show system status
    agent           Manage agents
    task            Manage tasks
    cost            Show cost reports
    provider        Manage LLM providers
    approval        Manage approvals
    db              Database operations
    config          Show configuration
"""

import sys
import os
import json
import argparse
from datetime import datetime, timedelta
from typing import Optional

# Add backend to path
sys.path.insert(0, os.path.join(os.path.dirname(__file__), '..', 'backend'))

from app.core.config import settings


def print_header(text: str):
    """Print formatted header"""
    print(f"\n{'='*60}")
    print(f"  {text}")
    print(f"{'='*60}\n")


def print_table(headers: list, rows: list):
    """Print simple table"""
    # Calculate column widths
    widths = [len(h) for h in headers]
    for row in rows:
        for i, cell in enumerate(row):
            widths[i] = max(widths[i], len(str(cell)))
    
    # Print header
    header_line = " | ".join(h.ljust(w) for h, w in zip(headers, widths))
    print(header_line)
    print("-" * len(header_line))
    
    # Print rows
    for row in rows:
        print(" | ".join(str(c).ljust(w) for c, w in zip(row, widths)))


def cmd_status(args):
    """Show system status"""
    print_header("FleetOps System Status")
    
    print(f"App Name:     {settings.APP_NAME}")
    print(f"Version:      0.1.0")
    print(f"Debug Mode:   {'YES' if settings.DEBUG else 'NO'}")
    print(f"Database:     {settings.DATABASE_URL.split('@')[-1]}")
    print(f"Redis:        {settings.REDIS_URL}")
    print(f"Log Level:    {settings.LOG_LEVEL}")
    
    # Check provider configs
    print_header("Configured Providers")
    providers = []
    
    # Safely check optional settings
    try:
        if hasattr(settings, 'OPENAI_API_KEY') and settings.OPENAI_API_KEY:
            providers.append("OpenAI")
    except AttributeError:
        pass
    try:
        if hasattr(settings, 'ANTHROPIC_API_KEY') and settings.ANTHROPIC_API_KEY:
            providers.append("Anthropic")
    except AttributeError:
        pass
    try:
        if hasattr(settings, 'OPENROUTER_API_KEY') and settings.OPENROUTER_API_KEY:
            providers.append("OpenRouter")
    except AttributeError:
        pass
    try:
        if hasattr(settings, 'GROQ_API_KEY') and settings.GROQ_API_KEY:
            providers.append("Groq")
    except AttributeError:
        pass
    try:
        if hasattr(settings, 'OLLAMA_URL') and settings.OLLAMA_URL:
            providers.append("Ollama")
    except AttributeError:
        pass
    
    if providers:
        for p in providers:
            print(f"  ✓ {p}")
    else:
        print("  None configured")


