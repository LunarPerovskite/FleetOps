        "AGENT_AUTO_APPROVE_LOW_RISK": settings.AGENT_AUTO_APPROVE_LOW_RISK,
    }
    
    for key, value in config.items():
        print(f"  {key}: {value}")


def main():
    parser = argparse.ArgumentParser(
        description="FleetOps CLI - Manage your agent fleet",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
    fleetops status                    Show system status
    fleetops agent list                List active agents
    fleetops task create "My Task"     Create a new task
    fleetops cost --today              Show today's costs
    fleetops provider list             List available LLM providers
    fleetops db migrate                Run database migrations
        """
    )
    
    subparsers = parser.add_subparsers(dest="command", help="Available commands")
    
    # Status command
    status_parser = subparsers.add_parser("status", help="Show system status")
    
    # Agent command
    agent_parser = subparsers.add_parser("agent", help="Manage agents")
    agent_sub = agent_parser.add_subparsers(dest="subcommand")
    agent_sub.add_parser("list", help="List agents")
    agent_create = agent_sub.add_parser("create", help="Create agent")
    agent_create.add_argument("name", help="Agent name")
    agent_status = agent_sub.add_parser("status", help="Agent status")
    agent_status.add_argument("agent_id", help="Agent ID")
    
    # Task command
    task_parser = subparsers.add_parser("task", help="Manage tasks")
    task_sub = task_parser.add_subparsers(dest="subcommand")
    task_sub.add_parser("list", help="List tasks")
    task_create = task_sub.add_parser("create", help="Create task")
    task_create.add_argument("title", help="Task title")
    task_status = task_sub.add_parser("status", help="Task status")
    task_status.add_argument("task_id", help="Task ID")
    
    # Cost command
    cost_parser = subparsers.add_parser("cost", help="Show cost reports")
    cost_parser.add_argument("--today", action="store_const", const="today", dest="period",
                            help="Show today's costs")
    cost_parser.add_argument("--week", action="store_const", const="week", dest="period",
                            help="Show this week's costs")
    cost_parser.add_argument("--month", action="store_const", const="month", dest="period",
                            help="Show this month's costs")
    cost_parser.set_defaults(period="today")
    
    # Provider command
    provider_parser = subparsers.add_parser("provider", help="Manage LLM providers")
    provider_sub = provider_parser.add_subparsers(dest="subcommand")
    provider_sub.add_parser("list", help="List providers")
    provider_status = provider_sub.add_parser("status", help="Provider status")
    provider_status.add_argument("provider", help="Provider name")
    
    # Approval command
    approval_parser = subparsers.add_parser("approval", help="Manage approvals")
    approval_sub = approval_parser.add_subparsers(dest="subcommand")
    approval_sub.add_parser("list", help="List pending approvals")
    approval_approve = approval_sub.add_parser("approve", help="Approve request")
    approval_approve.add_argument("approval_id", help="Approval ID")
    approval_reject = approval_sub.add_parser("reject", help="Reject request")
    approval_reject.add_argument("approval_id", help="Approval ID")
    
    # DB command
    db_parser = subparsers.add_parser("db", help="Database operations")
    db_sub = db_parser.add_subparsers(dest="subcommand")
    db_sub.add_parser("migrate", help="Run migrations")
    db_sub.add_parser("status", help="Database status")
    db_sub.add_parser("seed", help="Seed database")
    
    # Config command
    config_parser = subparsers.add_parser("config", help="Show configuration")
    
    args = parser.parse_args()
    
    if not args.command:
        parser.print_help()
        sys.exit(1)
    
    # Route to command handler
    commands = {
        "status": cmd_status,
        "agent": cmd_agent,
        "task": cmd_task,
        "cost": cmd_cost,
        "provider": cmd_provider,
        "approval": cmd_approval,
        "db": cmd_db,
        "config": cmd_config,
    }
    
    handler = commands.get(args.command)
    if handler:
        handler(args)
    else:
        print(f"Unknown command: {args.command}")
        sys.exit(1)


if __name__ == "__main__":
    main()
